generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Plan {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum AccountStatus {
  ACTIVE
  SUSPENDED
  CANCELLED
}

enum UserRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum ClientType {
  LEAD
  PROSPECT
  CUSTOMER
  INACTIVE
}

enum QuoteStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  EXPIRED
  CANCELLED
}

enum ProductionStatus {
  PENDING
  IN_PRODUCTION
  FINISHING
  INSTALLATION
  READY
  DELIVERED
  CANCELLED
}

enum ProductionPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum ProductionStageStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  BLOCKED
}

enum ContractStatus {
  DRAFT
  SENT
  SIGNED
  CANCELLED
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum TransactionStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

model Account {
  id          String        @id @default(uuid())
  name        String
  slug        String        @unique
  document    String?
  phone       String?
  email       String?
  address     String?
  city        String?
  state       String?
  zipCode     String?       @map("zip_code")
  logoUrl     String?       @map("logo_url")
  plan        Plan         @default(FREE)
  status      AccountStatus @default(ACTIVE)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  users           AccountUser[]
  clients         Client[]
  quotes          Quote[]
  productions     Production[]
  contracts       Contract[]
  transactions    Transaction[]
  categories      TransactionCategory[]
  templates       Template[]
  settings        Setting[]

  @@map("accounts")
}

model AccountUser {
  id         String   @id @default(uuid())
  accountId  String   @map("account_id")
  userId     String   @map("user_id")
  role       UserRole @default(MEMBER)
  name       String
  phone      String?
  avatarUrl  String?  @map("avatar_url")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdQuotes     Quote[]
  createdProductions Production[]

  @@unique([accountId, userId])
  @@map("account_users")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  accounts AccountUser[]

  @@map("users")
}

model Client {
  id        String     @id @default(uuid())
  accountId String     @map("account_id")
  name      String
  email     String?
  phone     String?
  document  String?
  address   String?
  city      String?
  state     String?
  zipCode   String?   @map("zip_code")
  type      ClientType @default(LEAD)
  source    String?
  notes     String?
  tags      String[]
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  account    Account     @relation(fields: [accountId], references: [id], onDelete: Cascade)
  quotes     Quote[]
  productions Production[]
  contracts  Contract[]

  @@index([accountId])
  @@index([accountId, type])
  @@map("clients")
}

model Quote {
  id           String      @id @default(uuid())
  accountId    String      @map("account_id")
  clientId     String?     @map("client_id")
  createdById  String?     @map("created_by_id")
  number       String
  title        String
  status       QuoteStatus @default(DRAFT)
  validityDate DateTime?   @map("validity_date")
  subtotal     Decimal     @default(0) @db.Decimal(12, 2)
  discountPercent  Decimal  @default(0) @map("discount_percent") @db.Decimal(5, 2)
  discountValue   Decimal  @default(0) @map("discount_value") @db.Decimal(12, 2)
  marginPercent   Decimal  @default(0) @map("margin_percent") @db.Decimal(5, 2)
  total         Decimal     @default(0) @db.Decimal(12, 2)
  notes        String?
  terms        String?
  pdfUrl       String?     @map("pdf_url")
  sentAt       DateTime?   @map("sent_at")
  approvedAt   DateTime?   @map("approved_at")
  rejectedAt   DateTime?   @map("rejected_at")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  account     Account        @relation(fields: [accountId], references: [id], onDelete: Cascade)
  client      Client?        @relation(fields: [clientId], references: [id], onDelete: SetNull)
  createdBy   AccountUser?   @relation(fields: [createdById], references: [id], onDelete: SetNull)
  environments QuoteEnvironment[]
  productions Production[]
  contracts  Contract[]
  transactions Transaction[]

  @@index([accountId])
  @@index([clientId])
  @@index([status])
  @@map("quotes")
}

model QuoteEnvironment {
  id          String   @id @default(uuid())
  quoteId     String   @map("quote_id")
  name        String
  description String?
  orderIndex  Int      @default(0) @map("order_index")
  createdAt   DateTime @default(now()) @map("created_at")

  quote  Quote      @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  items  QuoteItem[]

  @@index([quoteId])
  @@map("quote_environments")
}

model QuoteItem {
  id              String   @id @default(uuid())
  environmentId   String   @map("environment_id")
  templateItemId  String?  @map("template_item_id")
  name            String
  description     String?
  category        String?
  quantity        Decimal  @default(1) @db.Decimal(10, 2)
  unit            String   @default("un")
  unitCost        Decimal  @default(0) @map("unit_cost") @db.Decimal(12, 2)
  unitPrice       Decimal  @default(0) @map("unit_price") @db.Decimal(12, 2)
  totalCost       Decimal  @default(0) @map("total_cost") @db.Decimal(12, 2)
  totalPrice      Decimal  @default(0) @map("total_price") @db.Decimal(12, 2)
  marginPercent   Decimal  @default(0) @map("margin_percent") @db.Decimal(5, 2)
  orderIndex      Int      @default(0) @map("order_index")
  createdAt       DateTime @default(now()) @map("created_at")

  environment QuoteEnvironment @relation(fields: [environmentId], references: [id], onDelete: Cascade)

  @@index([environmentId])
  @@map("quote_items")
}

model Production {
  id          String            @id @default(uuid())
  accountId   String            @map("account_id")
  quoteId     String?           @map("quote_id")
  clientId    String?           @map("client_id")
  createdById String?           @map("created_by_id")
  title       String
  description String?
  status      ProductionStatus  @default(PENDING)
  priority    ProductionPriority @default(NORMAL)
  startDate   DateTime?         @map("start_date")
  deadline    DateTime?
  endDate     DateTime?         @map("end_date")
  totalValue  Decimal           @default(0) @map("total_value") @db.Decimal(12, 2)
  notes       String?
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  account     Account           @relation(fields: [accountId], references: [id], onDelete: Cascade)
  quote       Quote?            @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  client      Client?           @relation(fields: [clientId], references: [id], onDelete: SetNull)
  createdBy   AccountUser?      @relation(fields: [createdById], references: [id], onDelete: SetNull)
  stages      ProductionStage[]
  contracts   Contract[]
  transactions Transaction[]

  @@index([accountId])
  @@index([status])
  @@index([deadline])
  @@map("productions")
}

model ProductionStage {
  id          String               @id @default(uuid())
  productionId String              @map("production_id")
  name        String
  status      ProductionStageStatus @default(PENDING)
  notes       String?
  startedAt   DateTime?            @map("started_at")
  completedAt DateTime?            @map("completed_at")
  orderIndex  Int                  @default(0) @map("order_index")
  createdAt   DateTime             @default(now()) @map("created_at")
  updatedAt   DateTime             @updatedAt @map("updated_at")

  production Production @relation(fields: [productionId], references: [id], onDelete: Cascade)

  @@index([productionId])
  @@map("production_stages")
}

model Contract {
  id               String         @id @default(uuid())
  accountId        String         @map("account_id")
  quoteId          String?        @map("quote_id")
  productionId     String?        @map("production_id")
  clientId         String?        @map("client_id")
  number           String
  title            String
  template         String?
  content          String?
  status           ContractStatus @default(DRAFT)
  sentAt           DateTime?      @map("sent_at")
  signedAt         DateTime?      @map("signed_at")
  signedDocumentUrl String?       @map("signed_document_url")
  expiresAt        DateTime?      @map("expires_at")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  account    Account     @relation(fields: [accountId], references: [id], onDelete: Cascade)
  quote      Quote?      @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  production Production? @relation(fields: [productionId], references: [id], onDelete: SetNull)
  client     Client?     @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([accountId])
  @@index([status])
  @@map("contracts")
}

model Transaction {
  id            String            @id @default(uuid())
  accountId     String            @map("account_id")
  productionId  String?           @map("production_id")
  quoteId       String?           @map("quote_id")
  categoryId    String?           @map("category_id")
  type          TransactionType
  description   String
  amount        Decimal           @db.Decimal(12, 2)
  date          DateTime
  paymentMethod String?           @map("payment_method")
  status        TransactionStatus @default(PENDING)
  notes         String?
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")

  account   Account              @relation(fields: [accountId], references: [id], onDelete: Cascade)
  production Production?         @relation(fields: [productionId], references: [id], onDelete: SetNull)
  quote     Quote?               @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  category  TransactionCategory?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([accountId])
  @@index([type])
  @@index([date])
  @@index([categoryId])
  @@map("transactions")
}

model TransactionCategory {
  id        String          @id @default(uuid())
  accountId String          @map("account_id")
  name      String
  type      TransactionType
  color     String?
  icon      String?
  isDefault Boolean         @default(false) @map("is_default")
  createdAt DateTime       @default(now()) @map("created_at")

  account      Account         @relation(fields: [accountId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([accountId])
  @@map("transaction_categories")
}

model Template {
  id          String   @id @default(uuid())
  accountId   String?  @map("account_id")
  name        String
  description String?
  category    String?
  isPublic    Boolean  @default(false) @map("is_public")
  items       Json?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  account Account? @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@map("templates")
}

model Setting {
  id        String   @id @default(uuid())
  accountId String   @map("account_id")
  key       String
  value     Json?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, key])
  @@index([accountId])
  @@map("settings")
}
